# Server
PORT=4000
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db:5432/epic_fhir

# Epic FHIR (SMART Backend Services / JWT)
# Register a Backend Services app at https://fhir.epic.com/ and upload your public key.
EPIC_CLIENT_ID=your-epic-client-id-here

# Option A: path to RSA private key PEM file (recommended for local dev)
EPIC_PRIVATE_KEY_PATH=./keys/private.pem
EPIC_KEY_ID=epic-fhir-app-key-1

# Option B: inline private key (use \n for newlines in .env)
# EPIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_SCOPES=system/Patient.read system/Appointment.read system/Practitioner.read system/Location.read
EPIC_TEST_PATIENT_IDS=eq081-VQEgP8drUUqCWzHfw3,eIXesllypH3M9tAA5WdJftQ3

# HTTP client tuning
EPIC_REQUEST_TIMEOUT_MS=30000
EPIC_MAX_RETRIES=3
EPIC_RETRY_DELAY_MS=1000
